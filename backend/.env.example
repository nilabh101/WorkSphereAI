# WorkSphere AI — Backend Environment Configuration
# Copy to .env and fill in your values

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=WorkSphere AI
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://worksphere:password@localhost:5432/worksphere_db
# For async driver (optional future use):
# ASYNC_DATABASE_URL=postgresql+asyncpg://worksphere:password@localhost:5432/worksphere_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-256-bit-hex-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173

# ── First Admin User (seeded on first run) ────────────────────────────────────
ADMIN_EMAIL=admin@worksphere.ai
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Arjun Sharma
